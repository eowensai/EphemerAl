# Low-end laptop profile (text-only): optimized for low memory and responsiveness,
# not maximum quality.
OLLAMA_MODEL_SOURCE=llama3.2:3b
LLM_MODEL_NAME=ephemeral-default
LLM_CONTEXT_TOKENS=8192
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NO_CLOUD=1
